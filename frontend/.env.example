# Copy to .env.local and fill in your values
# Environment: local | development | staging | production
ENVIRONMENT=local

# Backend URL used by server-side proxy routes (not exposed to browser).
BACKEND_INTERNAL_URL=http://localhost:3001/api/v1

# ── OIDC Provider Configuration ──
# The app uses a generic OIDC provider — works with any OIDC-compliant IdP.
# Required: AUTH_OIDC_ID, AUTH_OIDC_SECRET, AUTH_OIDC_ISSUER

# ─── Local dev with Dex (docker compose --profile mssql-dex up -d or postgres-dex) ───
AUTH_OIDC_ID=fullstack-template
AUTH_OIDC_SECRET=fullstack-template-secret
AUTH_OIDC_ISSUER=http://localhost:8080/dex

# ─── Google ───
#   AUTH_OIDC_ID=<your-google-client-id>
#   AUTH_OIDC_SECRET=<your-google-client-secret>
#   AUTH_OIDC_ISSUER=https://accounts.google.com

# ─── Microsoft Entra ID (Azure AD) ───
#   AUTH_OIDC_ID=<your-azure-ad-client-id>
#   AUTH_OIDC_SECRET=<your-azure-ad-client-secret>
#   AUTH_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# ─── Keycloak ───
#   AUTH_OIDC_ID=<your-keycloak-client-id>
#   AUTH_OIDC_SECRET=<your-keycloak-client-secret>
#   AUTH_OIDC_ISSUER=https://keycloak.example.com/realms/<realm>

# ─── Bank/Enterprise custom IdP (manual endpoint config) ───
#   Set AUTH_OIDC_ISSUER to the IdP host (used for next-auth discovery only).
#   If the IdP doesn't support .well-known discovery, set backend config:
#     auth.discovery_mode: "manual"
#     auth.manual_endpoints.jwks_uri: "https://idp.bank.com/keys"
#     auth.manual_endpoints.issuer: "https://idp.bank.com"
#   For private-CA / self-signed certificates, mount the CA bundle and set
#   SSL_CERT_FILE instead of disabling verification.

# ── Required next-auth config ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
